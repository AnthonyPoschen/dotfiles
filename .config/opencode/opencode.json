{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "autoupdate": false,
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "ask",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~/": "deny",
      "rm -rf ~/*": "deny",
      "go *": "allow",
      "make *": "allow",
      "npm *": "allow",
      "grep": "allow",
      "ls": "allow",
      "cat": "allow"
    },
    "external_directory": {
      "~/tmp/99/": "allow",
      "~/tmp/99/*": "allow"
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "streaming": false
      },
      "models": {
        "qwen2.5-coder:14b-opencode": {
          "name": "Qwen2.5 Coder 14B",
          "tool_call": true
        }
      }
    }
  }
}
