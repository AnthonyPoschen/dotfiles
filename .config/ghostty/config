config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

font-family = "CaskaydiaMono Nerd Font"
font-style = Regular
font-size = 11
font-thicken = true
# adjust-cell-height = 5%
window-theme = ghostty
window-padding-x = 0
window-padding-y = 0
window-padding-balance = true

# Automatically close the app
confirm-close-surface = false
resize-overlay = never
window-save-state = always
gtk-toolbar-style = flat

cursor-style = "block"
cursor-style-blink = false

shell-integration-features = no-cursor,ssh-env

keybind = super+shift+,=reload_config
keybind = super+c=copy_to_clipboard
keybind = super+q=quit
keybind = ctrl+equal=increase_font_size:2
keybind = ctrl+minus=decrease_font_size:2
keybind = ctrl+0=reset_font_size

copy-on-select = false
clipboard-read = allow
clipboard-write = allow

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
